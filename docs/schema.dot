    "user_skill_map" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#FFE9A8"><FONT POINT-SIZE="12"><B>user_skill_map</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">skill_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#B8860B"];
