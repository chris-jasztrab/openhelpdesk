digraph schema {
  graph [rankdir=LR, splines=spline, overlap=false, nodesep=0.4, ranksep=1.2, fontname="Helvetica", bgcolor="#FAFAFA", pad=0.5];
  node  [shape=plain, fontname="Helvetica", fontsize=10];
  edge  [color="#888888", arrowsize=0.7, fontname="Helvetica", fontsize=8];
  labelloc=t; fontsize=22; label="LocalDesk Database Schema";
  subgraph cluster_Org {
    label="Org"; style="rounded,filled"; color="#DDDDDD"; fillcolor="#F0F0F0"; fontsize=14; fontname="Helvetica-Bold";
    "agent_skills" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#EAD1DC"><FONT POINT-SIZE="12"><B>agent_skills</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">group_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#A64D79"];
    "groups" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#EAD1DC"><FONT POINT-SIZE="12"><B>groups</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">assign_last_user_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#A64D79"];
    "group_user_map" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#EAD1DC"><FONT POINT-SIZE="12"><B>group_user_map</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">group_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#A64D79"];
    "holidays" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#EAD1DC"><FONT POINT-SIZE="12"><B>holidays</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#A64D79"];
    "locations" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#EAD1DC"><FONT POINT-SIZE="12"><B>locations</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#A64D79"];
  }
  subgraph cluster_AI {
    label="AI"; style="rounded,filled"; color="#DDDDDD"; fillcolor="#F0F0F0"; fontsize=14; fontname="Helvetica-Bold";
    "ai_classifications" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#FCE4D6"><FONT POINT-SIZE="12"><B>ai_classifications</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">ticket_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">overridden_by</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#B45F06"];
    "ai_duplicate_classifications" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#FCE4D6"><FONT POINT-SIZE="12"><B>ai_duplicate_classifications</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">type_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">location_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">chosen_ticket_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#B45F06"];
    "ai_group_classifications" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#FCE4D6"><FONT POINT-SIZE="12"><B>ai_group_classifications</B></FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#0B5394"><B>PK</B></FONT></TD><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">ticket_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">suggested_group_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT COLOR="#B45F06"><B>FK</B></FONT></TD><TD ALIGN="LEFT">applied_group_id</TD><TD ALIGN="LEFT"><FONT COLOR="#888888">int</FONT></TD></TR></TABLE>>, color="#B45F06"];
  }
