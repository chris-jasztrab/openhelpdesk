# Application
APP_NAME=OpenHelpDesk
APP_URL=http://localhost:8000
# Keep false in production. When true, PHP errors and stack traces (which can
# expose file paths, DB details, and other internals) are shown to users.
APP_DEBUG=false
APP_TIMEZONE=UTC

# Mail
# Master switch for outbound email. Leave true on production. Set to false on
# any dev, staging, or test instance so the app never delivers real mail —
# the helpdesk DB carries live SMTP credentials, so creating a test ticket
# would otherwise email every member of a notified group. SMTP host and
# credentials themselves are configured in Admin -> Settings, not here.
MAIL_ENABLED=true

# Transactional-mail bypass. When MAIL_ENABLED=false, the general kill switch
# also suppresses password-reset / account mail. Set this to true to let
# user-initiated transactional mail (e.g. password resets) send anyway, while
# keeping bulk ticket-notification mail suppressed. Has no effect when
# MAIL_ENABLED=true (everything already sends). Requires SMTP configured in
# Admin -> Settings.
MAIL_TRANSACTIONAL_ENABLED=false

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=localdesk
DB_USER=root
DB_PASS=

# File uploads
UPLOAD_MAX_SIZE=20971520
UPLOAD_ALLOWED_TYPES=application/pdf,image/jpeg,image/png,image/gif,image/webp,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain,application/zip
